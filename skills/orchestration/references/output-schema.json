{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Output Contract Schema",
  "description": "Shared schema for all subagent structured output blocks. Every agent's report MUST contain a YAML block at the top conforming to this schema. Supports: finder, implementor, fixer, plandescriber, verifier, qa, browser-tester, documentor, integrator, acceptance-gate, merge-coordinator.",
  "type": "object",
  "required": ["status", "resultSummary", "agentOutputs", "changedFiles", "artifacts", "evidence"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial"],
      "description": "Overall status of the agent task"
    },
    "resultSummary": {
      "type": "string",
      "description": "2-3 sentence summary of what was accomplished",
      "minLength": 10,
      "maxLength": 500
    },
    "agentOutputs": {
      "type": "object",
      "description": "Agent-specific output, keyed by agent name. Recognized agent keys include: finder, implementor, fixer, plandescriber, verifier, qa, browser-tester, documentor, integrator, acceptance-gate, merge-coordinator.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["status", "resultSummary"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "partial"]
          },
          "resultSummary": {
            "type": "string",
            "description": "Brief summary of this agent's results"
          },
          "buildPassed": {
            "type": ["boolean", "null"],
            "description": "Whether the build passed (mandatory for Implementor, Fixer, Integrator; null for read-only agents)"
          },
          "lintPassed": {
            "type": ["boolean", "null"],
            "description": "Whether lint passed (mandatory for Implementor, Fixer, Integrator; null for read-only agents)"
          },
          "buildOutput": {
            "type": ["string", "null"],
            "description": "Full stdout + stderr from build command"
          },
          "lintOutput": {
            "type": ["string", "null"],
            "description": "Full stdout + stderr from lint command (or 'No linter configured')"
          },
          "selfReview": {
            "type": "object",
            "description": "Self-review data from Self-Reviewing Implementor",
            "properties": {
              "confidence": { "type": "integer" },
              "preCheckPassed": { "type": "boolean" },
              "scopeGuardFlags": { "type": "array", "items": { "type": "string" } },
              "selfReviewIssues": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Issues found during self-review, each referencing a checkpoint ID"
              }
            },
            "required": ["confidence", "preCheckPassed", "scopeGuardFlags"]
          },
          "importScanResults": {
            "type": "array",
            "description": "Cross-file import scan results (Merge Coordinator only)",
            "items": {
              "type": "object",
              "properties": {
                "file": { "type": "string" },
                "imports": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "path": { "type": "string" },
                      "resolved": { "type": "boolean" },
                      "symbolMatch": { "type": "boolean" }
                    }
                  }
                }
              }
            }
          },
          "rootCauseAnalysis": {
            "type": "object",
            "description": "Root cause analysis (Fixer only; not used by other agents)",
            "properties": {
              "classification": {
                "type": "string",
                "enum": ["plan-omission", "implementation-error", "edge-case-miss", "integration-mismatch", "environment-issue"]
              },
              "primaryCause": { "type": "string" },
              "contributingFactors": {
                "type": "array",
                "items": { "type": "string" }
              },
              "fixApplied": { "type": "string" },
              "fixConfidence": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10
              },
              "crossModuleCheck": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "module": { "type": "string" },
                    "status": {
                      "type": "string",
                      "enum": ["unaffected", "affected", "needsReview"]
                    }
                  },
                  "required": ["module", "status"]
                }
              }
            },
            "required": ["classification", "primaryCause", "fixApplied", "fixConfidence"]
          },
          "wiringSummary": {
            "type": "object",
            "description": "Wiring summary (Integrator only; not used by other agents)",
            "properties": {
              "barrelFilesUpdated": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Barrel/index files modified to include new exports"
              },
              "diRegistrationsAdded": {
                "type": "array",
                "items": { "type": "string" },
                "description": "DI container registration statements added"
              },
              "routesAdded": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "method": { "type": "string" },
                    "path": { "type": "string" },
                    "handler": { "type": "string" }
                  },
                  "required": ["method", "path", "handler"]
                },
                "description": "Route registrations added"
              },
              "importsFixed": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "file": { "type": "string" },
                    "from": { "type": "string" },
                    "to": { "type": "string" }
                  },
                  "required": ["file", "from", "to"]
                },
                "description": "Import paths that were corrected"
              }
            },
            "required": ["barrelFilesUpdated", "diRegistrationsAdded", "routesAdded"]
          },
          "docsGenerated": {
            "type": "array",
            "description": "Documentation generated (Documentor only; not used by other agents)",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["inline", "readme", "api", "changelog", "migration"]
                },
                "files": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "summary": { "type": "string" }
              },
              "required": ["type", "files", "summary"]
            }
          },
          "acceptanceResults": {
            "type": "object",
            "description": "Acceptance criteria results (Acceptance Gate only; not used by other agents)",
            "properties": {
              "appStarted": { "type": "boolean" },
              "appStartDuration": { "type": "string" },
              "totalCheckpoints": { "type": "integer" },
              "passed": { "type": "integer" },
              "failed": { "type": "integer" },
              "skipped": { "type": "integer" },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "checkpointId": { "type": "string" },
                    "description": { "type": "string" },
                    "command": { "type": "string" },
                    "exitCode": { "type": "integer" },
                    "stdout": { "type": "string" },
                    "stderr": { "type": "string" },
                    "verdict": {
                      "type": "string",
                      "enum": ["pass", "fail", "skipped"]
                    }
                  },
                  "required": ["checkpointId", "verdict", "exitCode"]
                }
              }
            },
            "required": ["appStarted", "totalCheckpoints", "passed", "failed", "skipped", "details"]
          },
          "diffStats": {
            "type": "object",
            "description": "Diff statistics for file modifications (Implementor, Fixer only)",
            "properties": {
              "additions": { "type": "integer" },
              "deletions": { "type": "integer" },
              "filesChanged": { "type": "integer" }
            }
          },
          "evidenceMetrics": {
            "type": "object",
            "description": "Aggregated evidence quality metrics for this agent's output",
            "properties": {
              "avgQuality": { "type": "integer" },
              "completeness": { "type": "integer" },
              "precision": { "type": "integer" },
              "totalCount": { "type": "integer" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "description": "Anchored evidence for every substantive claim made by this agent. ALL agents MUST provide evidence for claims about files, exports, build status, test results, and behavioral patterns. Minimum 1 evidence entry required.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source", "method", "command", "excerpt", "result"],
        "properties": {
          "claim": {
            "type": "string",
            "description": "What the agent claims to be true"
          },
          "source": {
            "type": "string",
            "description": "File path the evidence comes from (or 'test', 'build', 'lint', 'analysis')"
          },
          "lines": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Specific line numbers [start, end] or empty array",
            "minItems": 0,
            "maxItems": 2
          },
          "method": {
            "type": "string",
            "enum": ["grep", "read", "glob", "stat", "test", "build", "lint", "run", "reason", "analysis"],
            "description": "How the evidence was obtained"
          },
          "command": {
            "type": "string",
            "description": "The exact command used to obtain this evidence"
          },
          "excerpt": {
            "type": "string",
            "description": "Relevant output excerpt proving the claim (or 'N/A' for reason-based claims)"
          },
          "result": {
            "type": "string",
            "description": "What the evidence proves: 'found', 'not_found', 'passed', 'failed', 'exists', 'not_exists', 'verified', 'analysis_complete'"
          },
          "contentHash": {
            "type": "string",
            "description": "SHA-256 hash of the source file content at the time evidence was collected. Provides chain-of-custody verification — re-hashing the file and comparing detects stale evidence.",
            "pattern": "^[a-f0-9]{64}$"
          },
          "qualityScore": {
            "type": "object",
            "description": "Evidence quality score (0-100) computed from completeness, precision, reproducibility, excerpt accuracy, and verifiability",
            "properties": {
              "total": { "type": "integer", "minimum": 0, "maximum": 100 },
              "completeness": { "type": "integer", "minimum": 0, "maximum": 100 },
              "precision": { "type": "integer", "minimum": 0, "maximum": 100 },
              "reproducibility": { "type": "integer", "minimum": 0, "maximum": 100 },
              "excerptAccuracy": { "type": "integer", "minimum": 0, "maximum": 100 },
              "verifiability": { "type": "integer", "minimum": 0, "maximum": 100 }
            },
            "required": ["total", "completeness", "precision", "reproducibility", "excerptAccuracy", "verifiability"]
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 timestamp of when evidence was collected",
            "format": "date-time"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "description": "Key decisions made during the task (required: Finder, PlanDescriber, QA, Integrator, Documentor; optional: others). Each decision MUST include evidence provenance.",
      "items": {
        "type": "object",
        "required": ["what", "why", "by_who"],
        "properties": {
          "what": { "type": "string", "description": "Decision description" },
          "why": { "type": "string", "description": "Rationale" },
          "by_who": { "type": "string", "description": "Agent name" },
          "evidence": {
            "type": "array",
            "description": "Evidence sources that informed this decision",
            "items": {
              "type": "object",
              "properties": {
                "source": { "type": "string" },
                "excerpt": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "description": "Non-blocking issues or concerns discovered",
      "items": { "type": "string" }
    },
    "changedFiles": {
      "type": "array",
      "description": "Files created or modified by this agent",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "description": "Descriptions of artifacts produced (reports, manifests, test files, documentation, etc.)",
      "items": { "type": "string" }
    }
  }
}
