<?xml version="1.0"?>
<ruleset name="Custom Project Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
    <description>Custom ruleset - focused on error prone and code style only (PMD 7.x)</description>

    <!-- Include error-prone rules, excluding some noisy ones -->
    <rule ref="category/java/errorprone.xml"/>

    <!-- Include code-style rules, excluding some noisy ones -->
    <rule ref="category/java/codestyle.xml">
        <exclude name="LongVariable"/>
        <exclude name="ShortVariable"/>
        <exclude name="OnlyOneReturn"/>
    </rule>

    <!-- Relax method NCSS (Non-Commenting Source Statements) threshold to 75 lines -->
    <rule ref="category/java/design.xml/NcssCount">
        <properties>
            <property name="methodReportLevel" value="75"/>
        </properties>
    </rule>
</ruleset>
