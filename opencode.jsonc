{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "mcp": {
    "searxng": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true
    },
    "clickup": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-remote", "https://mcp.clickup.com/mcp"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": true
    }
  },
  "agent": {
    "orchestrator": {
      "description": "Entry-point coordinator for the multi-agent workflow. Delegates work to brainstormer, finder, planner, security, engineer, architecture, qa, and coder agents.",
      "mode": "primary",
      
      "file": "~/agents/orchestrator.md",
      "permission": {
        "task": "allow",
        "edit": "deny",
        "bash": "allow",
        "question": "allow"
      }
    },
    "brainstormer": {
      "description": "Proactively gathers and clarifies user requirements, analyzes them, and presents multiple comparable solutions for the user to select from.",
      "mode": "subagent",
      
      "file": "~/agents/brainstormer.md",
      "permission": {
        "read": "allow",
        "question": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "finder": {
      "description": "Explores the current codebase to collect all information needed by the planner and reviewers, including structure, conventions, dependencies, and existing code.",
      "mode": "subagent",
      
      "file": "~/agents/finder.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "planner": {
      "description": "Creates and refines structured implementation plans using the plan-protocol skill, then requests approval from security, engineer, architecture, and qa reviewers.",
      "mode": "subagent",
      
      "file": "~/agents/planner.md",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "skill": {
          "*": "allow"
        },
        "task": "allow"
      }
    },
    "security": {
      "description": "Reviews implementation plans and implemented code from a security perspective using the plan-protocol skill and available security scanners.",
      "mode": "subagent",
      
      "file": "~/agents/security.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "*": "allow"
        },
        "edit": "deny",
        "bash": "deny"
      }
    },
    "engineer": {
      "description": "Reviews implementation plans and implemented code for engineering best practices, performance, maintainability, and runs static/dependency security scans.",
      "mode": "subagent",
      
      "file": "~/agents/engineer.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "*": "allow"
        },
        "edit": "deny",
        "bash": "deny"
      }
    },
    "architecture": {
      "description": "Reviews implementation plans and implemented code for system architecture fit, trade-offs, ADRs, C4 diagrams, and alignment with long-term design goals.",
      "mode": "subagent",
      
      "file": "~/agents/architecture.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "plan-protocol": "allow"
        },
        "edit": "deny",
        "bash": "deny"
      }
    },
    "qa": {
      "description": "Reviews implementation plans and verifies implemented code against acceptance criteria, test coverage, and alignment with the plan using the plan-protocol skill.",
      "mode": "subagent",
      
      "file": "~/agents/qa.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "plan-protocol": "allow"
        },
        "edit": "deny",
        "bash": "deny"
      }
    },
    "coder": {
      "description": "Implements code exactly according to an approved plan; if the plan is not approved, returns it to the planner for improvement.",
      "mode": "subagent",
      
      "file": "~/agents/coder.md",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "skill": {
          "*": "allow"
        },
        "task": "allow"
      }
    }
  }
}
