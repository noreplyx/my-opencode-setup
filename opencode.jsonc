{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "mcp": {
    "searxng": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true
    },
    "clickup": {
      "type": "remote",
      // "command": ["bunx", "-y", "mcp-remote", "https://mcp.clickup.com/mcp"],
      "url":"https://mcp.clickup.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  },
  "agent":{
    "architecture":{
      "model": "ollama-cloud/gemma4:31b"
    },
    "brainstormer":{
      "model": "ollama-cloud/gemma4:31b"
    },
    "code-explorer":{
      "model": "ollama-cloud/nemotron-3-nano:30b"
    },
    "coder":{
      "model": "ollama-cloud/kimi-k2.7-code"
    },
    "engineer":{
      "model": "ollama-cloud/gemma4:31b"
    },
    "linter":{
      "model": "ollama-cloud/nemotron-3-nano:30b",
    },
    "planner":{
      "model": "ollama-cloud/kimi-k2.7-code"
    },
    "qa":{
      "model": "ollama-cloud/gemma4:31b"
    },
    "security-scanner":{
      "model": "ollama-cloud/nemotron-3-nano:30b"
    },
    "security":{
      "model": "ollama-cloud/gemma4:31b"
    },
    "tester":{
      "model": "ollama-cloud/gemma4:31b"
    }
  }
}
