{
  "name": "opencode-analyzer",
  "version": "1.0.0",
  "description": "AI Agent System Analytic Tool - capture, analyze and visualize agent interactions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsc && node --watch dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:migrate-data": "node dist/scripts/migrate-from-sqlite.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.18.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.0",
    "sql.js": "^1.10.0",
    "typescript": "^6.0.3"
  }
}
